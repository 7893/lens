{
  "name": "lens",
  "version": "1.0.0",
  "private": true,
  "description": "Lens: Smart Image Gallery with Semantic Search",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "setup:infra": "npm run setup:local-db",
    "setup:local-db": "npm run setup:local-db --workspace=@lens/engine",
    "dev:backend": "npm run dev --workspace=@lens/engine",
    "test": "vitest run",
    "build": "npm run build --workspaces",
    "lint": "eslint . && prettier --check .",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.74.0"
  }
}
