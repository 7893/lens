{
  "name": "lens",
  "version": "1.0.0",
  "private": true,
  "description": "Lens: Smart Image Gallery with Semantic Search",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "setup:infra": "npm run setup:local-db",
    "setup:local-db": "npm run setup:local-db --workspace=@lens/engine",
    "dev:backend": "npm run dev --workspace=@lens/engine",
    "test": "vitest run",
    "build": "npm run build --workspaces",
    "lint": "eslint . && prettier --check .",
    "typecheck": "npm run typecheck --workspaces"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5"
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
